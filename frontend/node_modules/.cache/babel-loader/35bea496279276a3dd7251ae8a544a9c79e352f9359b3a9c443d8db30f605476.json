{"ast":null,"code":"export const API='http://localhost:5000/api';export const api={get:url=>fetch(API+url).then(r=>r.json()),post:(url,body)=>fetch(API+url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}).then(r=>r.json()),put:(url,body)=>fetch(API+url,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}).then(r=>r.json()),upload:(url,formData)=>fetch(API+url,{method:'POST',body:formData}).then(r=>r.json())};","map":{"version":3,"names":["API","api","get","url","fetch","then","r","json","post","body","method","headers","JSON","stringify","put","upload","formData"],"sources":["/home/aarya/Desktop/medbook/frontend/src/api/api.js"],"sourcesContent":["export const API = 'http://localhost:5000/api';\n\nexport const api = {\n  get: (url) => fetch(API + url).then(r => r.json()),\n  post: (url, body) => fetch(API + url, {\n    method: 'POST', \n    headers: { 'Content-Type': 'application/json' }, \n    body: JSON.stringify(body)\n  }).then(r => r.json()),\n  put: (url, body) => fetch(API + url, {\n    method: 'PUT', \n    headers: { 'Content-Type': 'application/json' }, \n    body: JSON.stringify(body)\n  }).then(r => r.json()),\n  upload: (url, formData) => fetch(API + url, { \n    method: 'POST', \n    body: formData \n  }).then(r => r.json()),\n};\n"],"mappings":"AAAA,MAAO,MAAM,CAAAA,GAAG,CAAG,2BAA2B,CAE9C,MAAO,MAAM,CAAAC,GAAG,CAAG,CACjBC,GAAG,CAAGC,GAAG,EAAKC,KAAK,CAACJ,GAAG,CAAGG,GAAG,CAAC,CAACE,IAAI,CAACC,CAAC,EAAIA,CAAC,CAACC,IAAI,CAAC,CAAC,CAAC,CAClDC,IAAI,CAAEA,CAACL,GAAG,CAAEM,IAAI,GAAKL,KAAK,CAACJ,GAAG,CAAGG,GAAG,CAAE,CACpCO,MAAM,CAAE,MAAM,CACdC,OAAO,CAAE,CAAE,cAAc,CAAE,kBAAmB,CAAC,CAC/CF,IAAI,CAAEG,IAAI,CAACC,SAAS,CAACJ,IAAI,CAC3B,CAAC,CAAC,CAACJ,IAAI,CAACC,CAAC,EAAIA,CAAC,CAACC,IAAI,CAAC,CAAC,CAAC,CACtBO,GAAG,CAAEA,CAACX,GAAG,CAAEM,IAAI,GAAKL,KAAK,CAACJ,GAAG,CAAGG,GAAG,CAAE,CACnCO,MAAM,CAAE,KAAK,CACbC,OAAO,CAAE,CAAE,cAAc,CAAE,kBAAmB,CAAC,CAC/CF,IAAI,CAAEG,IAAI,CAACC,SAAS,CAACJ,IAAI,CAC3B,CAAC